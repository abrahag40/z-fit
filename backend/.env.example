# App
NODE_ENV=development
PORT=3000

# Swagger
SWAGGER_TITLE=ZaharDev Gym Manager API
SWAGGER_DESC=Backend MVP para administración de gimnasios
SWAGGER_VERSION=1.0.0
SWAGGER_PATH=/docs

# Database (Prisma)
DATABASE_URL="postgresql://zgym:zgym@localhost:5432/zgym?schema=public"

# JWT
# OBLIGATORIO: generar un secreto real con `openssl rand -hex 48`.
# Joi rechazará valores < 32 chars o valores por defecto inseguros.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_48_AT_LEAST_32_CHARS_________
JWT_EXPIRES_IN=3600

# CORS
# Lista CSV de orígenes permitidos. NO usar "*" en producción.
CORS_ORIGIN=http://localhost:3000

# Rate limiting para /auth/*
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=10

# Feature flags
# Los endpoints /debug/* solo se montan si esto es true.
ENABLE_DEBUG_ENDPOINTS=false
